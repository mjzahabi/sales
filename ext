<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CASS Training Overview — Chrome Extension Tools</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=Barlow:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&display=swap" rel="stylesheet">
<style>
:root {
  --cox-navy: #06262D;
  --cox-blue: #1D3E74;
  --cyan: #00BCDD;
  --orange: #FF570C;
  --gold: #FCAF17;
  --vauto-orange: #FF821C;
  --gfp-green: #4ae3b5;
  --bg: #F2F5F7;
  --white: #ffffff;
  --text: #2d2d44;
  --text-light: #5a6875;
  --border: #DDE5EA;
  --font-head: 'Barlow Condensed', sans-serif;
  --font-body: 'Barlow', sans-serif;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }

body {
  font-family: var(--font-body);
  background: var(--bg);
  color: var(--text);
  font-size: 16px;
  line-height: 1.6;
  min-height: 100vh;
}

/* ── Header ─────────────────────────────────────────── */
.header {
  background: var(--cox-navy);
  padding: 40px 60px;
  position: relative;
  overflow: hidden;
}

.header::before {
  content: '';
  position: absolute;
  top: -50px; right: -100px;
  width: 400px; height: 400px;
  background: linear-gradient(135deg, rgba(0,188,221,0.08) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

.header-inner {
  max-width: 1400px;
  margin: 0 auto;
  position: relative;
  z-index: 1;
}

.header-eyebrow {
  font-family: var(--font-head);
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--cyan);
  margin-bottom: 12px;
  display: flex;
  align-items: center;
  gap: 10px;
}

.header-eyebrow::before {
  content: '';
  display: inline-block;
  width: 28px; height: 2px;
  background: var(--cyan);
}

.header h1 {
  font-family: var(--font-head);
  font-size: clamp(36px, 5vw, 56px);
  font-weight: 900;
  line-height: 1;
  text-transform: uppercase;
  color: var(--white);
  letter-spacing: -1px;
  margin-bottom: 12px;
}

.header h1 span { color: var(--cyan); }

.header-desc {
  font-size: 18px;
  font-weight: 300;
  color: rgba(255,255,255,0.65);
  max-width: 600px;
}

/* ── Tab Navigation ─────────────────────────────────── */
.tab-nav {
  background: var(--white);
  border-bottom: 1px solid var(--border);
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2px 20px rgba(0,0,0,0.05);
}

.tab-nav-inner {
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 60px;
  display: flex;
  gap: 0;
}

.tab-btn {
  position: relative;
  padding: 20px 32px;
  font-family: var(--font-head);
  font-size: 14px;
  font-weight: 700;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--text-light);
  background: none;
  border: none;
  cursor: pointer;
  transition: all 0.25s ease;
  display: flex;
  align-items: center;
  gap: 10px;
}

.tab-btn::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 3px;
  background: transparent;
  transition: all 0.25s ease;
}

.tab-btn:hover {
  color: var(--text);
}

.tab-btn.active {
  color: var(--text);
}

.tab-btn.active::after {
  background: var(--tab-color);
}

.tab-btn[data-tab="pi"] { --tab-color: var(--cyan); }
.tab-btn[data-tab="xtime"] { --tab-color: var(--orange); }
.tab-btn[data-tab="vauto"] { --tab-color: var(--vauto-orange); }
.tab-btn[data-tab="gfp"] { --tab-color: #4ae3b5; }

.tab-badge {
  width: 28px; height: 28px;
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 10px;
  font-weight: 900;
  color: var(--white);
}

.tab-btn[data-tab="pi"] .tab-badge { background: var(--cyan); }
.tab-btn[data-tab="xtime"] .tab-badge { background: var(--orange); }
.tab-btn[data-tab="vauto"] .tab-badge { background: var(--vauto-orange); }
.tab-btn[data-tab="gfp"] .tab-badge { background: #4ae3b5; }

/* ── Tab Content ────────────────────────────────────── */
.tab-content {
  display: none;
  animation: fadeIn 0.4s ease;
}

.tab-content.active {
  display: block;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

/* ── Content Wrapper ────────────────────────────────── */
.content-wrapper {
  max-width: 1400px;
  margin: 0 auto;
  padding: 60px;
}

/* ── Tool Hero Banners ──────────────────────────────── */
.tool-hero {
  border-radius: 16px;
  padding: 48px;
  margin-bottom: 48px;
  position: relative;
  overflow: hidden;
}

.tool-hero.pi { background: linear-gradient(135deg, var(--cox-navy) 0%, var(--cox-blue) 100%); }
.tool-hero.xtime { background: linear-gradient(135deg, #050F3D 0%, var(--cox-blue) 50%, var(--orange) 100%); }
.tool-hero.vauto { background: linear-gradient(135deg, #1a1a2e 0%, #2d2d44 50%, #3d3d5c 100%); }
.tool-hero.gfp { background: linear-gradient(135deg, #0f1117 0%, #181b24 50%, #1f2330 100%); }

.tool-hero::before {
  content: '';
  position: absolute;
  top: -50%; right: -10%;
  width: 500px; height: 500px;
  border-radius: 50%;
  pointer-events: none;
}

.tool-hero.pi::before { background: radial-gradient(circle, rgba(0,188,221,0.15) 0%, transparent 70%); }
.tool-hero.xtime::before { background: radial-gradient(circle, rgba(255,87,12,0.2) 0%, transparent 70%); }
.tool-hero.vauto::before { background: radial-gradient(circle, rgba(255,130,28,0.15) 0%, transparent 70%); }
.tool-hero.gfp::before { background: radial-gradient(circle, rgba(74,227,181,0.15) 0%, transparent 70%); }

.tool-hero-content {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: 1fr auto;
  align-items: center;
  gap: 40px;
}

.tool-hero h2 {
  font-family: var(--font-head);
  font-size: 42px;
  font-weight: 900;
  line-height: 1;
  text-transform: uppercase;
  color: var(--white);
  margin-bottom: 16px;
}

.tool-hero h2 span.pi { color: var(--cyan); }
.tool-hero h2 span.xtime { color: var(--orange); }
.tool-hero h2 span.vauto { color: var(--vauto-orange); }
.tool-hero h2 span.gfp { color: var(--gfp-green); }

.tool-hero p {
  font-size: 17px;
  font-weight: 300;
  color: rgba(255,255,255,0.75);
  max-width: 500px;
  line-height: 1.7;
}

.tool-tags {
  display: flex;
  gap: 8px;
  margin-top: 20px;
  flex-wrap: wrap;
}

.tool-tag {
  padding: 6px 14px;
  border-radius: 4px;
  font-family: var(--font-head);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 1px;
  text-transform: uppercase;
  background: rgba(255,255,255,0.1);
  color: rgba(255,255,255,0.8);
  border: 1px solid rgba(255,255,255,0.15);
}

.tool-icon {
  width: 120px; height: 120px;
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48px;
  box-shadow: 0 20px 50px rgba(0,0,0,0.3);
}

.tool-icon.pi { background: linear-gradient(135deg, var(--cyan), #0099b5); }
.tool-icon.xtime { background: linear-gradient(135deg, var(--orange), #FF821C); }
.tool-icon.vauto { background: linear-gradient(135deg, var(--vauto-orange), var(--gold)); }
.tool-icon.gfp { background: linear-gradient(135deg, var(--gfp-green), #2dd4a0); }

/* ── Section Cards ──────────────────────────────────── */
.section-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
  gap: 24px;
  margin-bottom: 48px;
}

.section-card {
  background: var(--white);
  border-radius: 12px;
  padding: 32px;
  border: 1px solid var(--border);
  transition: all 0.25s ease;
  position: relative;
  overflow: hidden;
}

.section-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 40px rgba(0,0,0,0.08);
}

.section-card-header {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 16px;
}

.section-icon {
  width: 48px; height: 48px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
}

.section-icon.cyan { background: rgba(0,188,221,0.12); }
.section-icon.orange { background: rgba(255,87,12,0.12); }
.section-icon.gold { background: rgba(252,175,23,0.12); }
.section-icon.navy { background: rgba(29,62,116,0.12); }
.section-icon.grey { background: rgba(90,104,117,0.12); }
.section-icon.green { background: rgba(74,227,181,0.12); }

.section-card h3 {
  font-family: var(--font-head);
  font-size: 18px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: var(--text);
}

.section-card p {
  color: var(--text-light);
  font-size: 15px;
  line-height: 1.7;
}

.section-card ul {
  margin-top: 16px;
  padding-left: 0;
  list-style: none;
}

.section-card ul li {
  padding: 8px 0;
  border-bottom: 1px solid var(--border);
  font-size: 14px;
  color: var(--text);
  display: flex;
  align-items: flex-start;
  gap: 10px;
}

.section-card ul li:last-child { border-bottom: none; }

.section-card ul li::before {
  content: '→';
  color: var(--cyan);
  font-weight: 600;
  flex-shrink: 0;
}

.section-card.xtime ul li::before { color: var(--orange); }
.section-card.vauto ul li::before { color: var(--vauto-orange); }
.section-card.gfp ul li::before { color: var(--gfp-green); }

/* ── Full Width Sections ────────────────────────────── */
.full-section {
  background: var(--white);
  border-radius: 12px;
  padding: 40px;
  border: 1px solid var(--border);
  margin-bottom: 32px;
}

.full-section h3 {
  font-family: var(--font-head);
  font-size: 22px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: var(--text);
  margin-bottom: 8px;
  display: flex;
  align-items: center;
  gap: 12px;
}

.full-section h3 .num {
  width: 32px; height: 32px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: 800;
  color: var(--white);
}

.full-section h3 .num.cyan { background: var(--cyan); }
.full-section h3 .num.orange { background: var(--orange); }
.full-section h3 .num.gold { background: var(--vauto-orange); }
.full-section h3 .num.green { background: var(--gfp-green); }

.full-section .lead {
  color: var(--text-light);
  font-size: 16px;
  margin-bottom: 24px;
}

/* ── Steps ──────────────────────────────────────────── */
.steps-row {
  display: flex;
  gap: 24px;
  overflow-x: auto;
  padding-bottom: 8px;
}

.step-item {
  flex: 1;
  min-width: 180px;
  background: var(--bg);
  border-radius: 10px;
  padding: 24px;
  text-align: center;
  position: relative;
}

.step-item::after {
  content: '→';
  position: absolute;
  right: -18px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 20px;
  color: var(--border);
}

.step-item:last-child::after { display: none; }

.step-num {
  width: 36px; height: 36px;
  border-radius: 50%;
  margin: 0 auto 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-head);
  font-size: 16px;
  font-weight: 800;
  color: var(--white);
}

.step-num.cyan { background: var(--cyan); }
.step-num.orange { background: var(--orange); }
.step-num.gold { background: var(--vauto-orange); }
.step-num.green { background: var(--gfp-green); }

.step-item h4 {
  font-family: var(--font-head);
  font-size: 13px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 8px;
  color: var(--text);
}

.step-item p {
  font-size: 13px;
  color: var(--text-light);
  line-height: 1.5;
}

/* ── Tips Grid ──────────────────────────────────────── */
.tips-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 16px;
}

.tip-card {
  display: flex;
  gap: 16px;
  padding: 20px;
  background: var(--bg);
  border-radius: 10px;
  border-left: 3px solid var(--cyan);
}

.tip-card.orange { border-left-color: var(--orange); }
.tip-card.gold { border-left-color: var(--vauto-orange); }
.tip-card.green { border-left-color: var(--gfp-green); }

.tip-num {
  width: 28px; height: 28px;
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-head);
  font-size: 12px;
  font-weight: 800;
  color: var(--white);
  flex-shrink: 0;
}

.tip-num.cyan { background: var(--cyan); }
.tip-num.orange { background: var(--orange); }
.tip-num.gold { background: var(--vauto-orange); }
.tip-num.green { background: var(--gfp-green); }

.tip-body h4 {
  font-size: 14px;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 4px;
}

.tip-body p {
  font-size: 13px;
  color: var(--text-light);
  line-height: 1.5;
}

/* ── Reports List ───────────────────────────────────── */
.reports-list {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 16px;
}

.report-item {
  display: flex;
  gap: 16px;
  padding: 20px;
  background: var(--bg);
  border-radius: 10px;
  align-items: flex-start;
}

.report-icon {
  width: 44px; height: 44px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  flex-shrink: 0;
}

.report-icon.cyan { background: linear-gradient(135deg, var(--cyan), #0099b5); }
.report-icon.orange { background: linear-gradient(135deg, var(--orange), #FF821C); }
.report-icon.gold { background: linear-gradient(135deg, var(--vauto-orange), var(--gold)); }
.report-icon.navy { background: linear-gradient(135deg, var(--cox-blue), #0d2850); }
.report-icon.grey { background: linear-gradient(135deg, #5a6875, #73848d); }
.report-icon.green { background: linear-gradient(135deg, var(--gfp-green), #2dd4a0); }

.report-info h4 {
  font-size: 15px;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 4px;
}

.report-info p {
  font-size: 13px;
  color: var(--text-light);
  line-height: 1.5;
}

/* ── Footer ─────────────────────────────────────────── */
.footer {
  background: var(--cox-navy);
  padding: 32px 60px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 40px;
}

.footer-left {
  display: flex;
  align-items: center;
  gap: 16px;
}

.footer-badge {
  width: 40px; height: 40px;
  background: var(--cox-blue);
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-head);
  font-weight: 900;
  font-size: 14px;
  color: var(--cyan);
}

.footer-name {
  font-family: var(--font-head);
  font-weight: 700;
  font-size: 14px;
  color: var(--white);
  text-transform: uppercase;
  letter-spacing: 1px;
}

.footer-sub {
  font-size: 12px;
  color: rgba(255,255,255,0.5);
}

.footer-right {
  font-size: 12px;
  color: rgba(255,255,255,0.4);
  text-align: right;
}

/* ── Chrome Store & Artifact Buttons ───────────────── */
.btn-chrome {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  margin-top: 20px;
  padding: 10px 20px;
  border-radius: 8px;
  font-family: var(--font-head);
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 1px;
  text-transform: uppercase;
  text-decoration: none;
  background: rgba(255,255,255,0.12);
  color: var(--white);
  border: 1px solid rgba(255,255,255,0.25);
  transition: all 0.2s ease;
  backdrop-filter: blur(4px);
}
.btn-chrome:hover {
  background: rgba(255,255,255,0.22);
  border-color: rgba(255,255,255,0.45);
  transform: translateY(-1px);
}
.btn-chrome svg { flex-shrink: 0; }

.btn-chrome.pi-store:hover { box-shadow: 0 4px 16px rgba(0,188,221,0.3); }
.btn-chrome.xtime-store:hover { box-shadow: 0 4px 16px rgba(255,87,12,0.3); }
.btn-chrome.vauto-store:hover { box-shadow: 0 4px 16px rgba(255,130,28,0.3); }
.btn-chrome.gfp-store:hover { box-shadow: 0 4px 16px rgba(74,227,181,0.3); }

.btn-artifacts {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 20px;
  border-radius: 8px;
  font-family: var(--font-head);
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 1px;
  text-transform: uppercase;
  text-decoration: none;
  background: linear-gradient(135deg, var(--orange), #FF821C);
  color: var(--white);
  border: none;
  cursor: pointer;
  transition: all 0.2s ease;
  white-space: nowrap;
  box-shadow: 0 2px 12px rgba(255,87,12,0.35);
}
.btn-artifacts:hover {
  transform: translateY(-1px);
  box-shadow: 0 6px 20px rgba(255,87,12,0.45);
}

.tab-nav-inner {
  /* override to allow space-between */
}
.tab-nav-actions {
  margin-left: auto;
  display: flex;
  align-items: center;
  padding: 8px 0;
}

/* ── Responsive ─────────────────────────────────────── */
@media (max-width: 900px) {
  .header { padding: 32px; }
  .tab-nav-inner { padding: 0 20px; overflow-x: auto; }
  .tab-btn { padding: 16px 20px; font-size: 12px; }
  .content-wrapper { padding: 32px; }
  .tool-hero { padding: 32px; }
  .tool-hero-content { grid-template-columns: 1fr; }
  .tool-icon { display: none; }
  .section-grid { grid-template-columns: 1fr; }
  .steps-row { flex-direction: column; }
  .step-item::after { display: none; }
  .footer { flex-direction: column; gap: 20px; text-align: center; }
  .footer-right { text-align: center; }
}

/* ── Navigator Tab Styles ─────────────────────────── */

  .nav-wrap{
    --cox-blue: #0C80DF;
    --cox-blue-dark: #0A68B8;
    --cox-blue-light: #E8F4FD;
    --cox-orange: #E84C0E;
    --dark: #0F1923;
    --light: #F7F9FC;
    --light-2: #EEF2F7;
    --light-3: #E2E8F0;
    --surface: #FFFFFF;
    --text-primary: #0F1923;
    --text-secondary: #4A5568;
    --text-muted: #8A9BB0;
    --border: #E2E8F0;
    --border-blue: rgba(12,128,223,0.2);
    --shadow-sm: 0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
    --shadow-md: 0 4px 16px rgba(0,0,0,0.08), 0 2px 6px rgba(0,0,0,0.04);
    --shadow-lg: 0 12px 40px rgba(0,0,0,0.1), 0 4px 12px rgba(0,0,0,0.06);
  }

  

  

  .nav-wrap .container{ max-width: 1400px; margin: 0 auto; padding: 0 48px; position: relative; }

  /* ---- HERO ---- */
  .nav-wrap .hero{
    background: linear-gradient(160deg, var(--dark) 0%, #1A2E45 60%, #0C3A6B 100%);
    padding: 80px 48px 96px;
    position: relative;
    overflow: hidden;
  }

  .nav-wrap .hero::before{
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
  }

  .nav-wrap .hero-inner{
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: 64px;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .nav-wrap .hero-badge{
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
