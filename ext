    font-weight: 700;
    padding: 3px 9px;
    border-radius: 4px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .nav-wrap .modal-close{
    width: 32px; height: 32px;
    border-radius: 8px;
    background: var(--light);
    border: 1px solid var(--border);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    color: var(--text-muted);
    transition: background 0.15s, color 0.15s;
    flex-shrink: 0;
  }
  .nav-wrap .modal-close:hover{ background: var(--light-3); color: var(--text-primary); }

  .nav-wrap .modal-desc{
    padding: 16px 28px;
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.6;
    background: var(--light);
    border-bottom: 1px solid var(--border);
  }

  .nav-wrap .modal-actions-label{
    padding: 16px 28px 8px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .nav-wrap .modal-actions{ padding: 0 12px 16px; }

  .nav-wrap .modal-action-item{
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 12px 16px;
    border-radius: 10px;
    transition: background 0.12s;
    cursor: default;
  }
  .nav-wrap .modal-action-item:hover{ background: var(--light); }

  .nav-wrap .modal-action-icon{
    width: 32px; height: 32px;
    border-radius: 8px;
    background: var(--cox-blue-light);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    flex-shrink: 0;
  }

  .nav-wrap .modal-action-text{ flex: 1; }
  .nav-wrap .modal-action-name{
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 3px;
    font-family: 'DM Sans', sans-serif;
  }
  .nav-wrap .modal-action-desc{
    font-size: 12px;
    color: var(--text-secondary);
    line-height: 1.45;
  }

  .nav-wrap .modal-footer{
    padding: 14px 28px;
    border-top: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: var(--text-muted);
  }

  .nav-wrap .ctx-item{ cursor: pointer; }
  .nav-wrap .ctx-item:hover .ctx-item-action{ color: var(--cox-blue); }


  /* ---- HOVER TOOLTIPS ---- */
  .nav-wrap .ctx-item{
    position: relative;
  }

  .nav-wrap .ctx-tooltip{
    display: none;
    position: absolute;
    left: calc(100% + 12px);
    top: 50%;
    transform: translateY(-50%);
    background: white;
    border: 1px solid var(--border);
    border-radius: 14px;
    box-shadow: 0 16px 48px rgba(0,0,0,0.14), 0 4px 12px rgba(0,0,0,0.07);
    width: 280px;
    z-index: 200;
    pointer-events: none;
    animation: tooltipIn 0.18s cubic-bezier(0.34,1.4,0.64,1) both;
  }

  @keyframes tooltipIn {
    from { opacity: 0; transform: translateY(-50%) translateX(-6px); }
    to   { opacity: 1; transform: translateY(-50%) translateX(0); }
  }

  /* Arrow pointing left */
  .nav-wrap .ctx-tooltip::before{
    content: '';
    position: absolute;
    left: -7px;
    top: 50%;
    transform: translateY(-50%);
    width: 13px; height: 13px;
    background: white;
    border-left: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    transform: translateY(-50%) rotate(45deg);
  }

  .nav-wrap .ctx-item:hover .ctx-tooltip{
    display: block;
  }

  .nav-wrap .ctx-tooltip-header{
    padding: 12px 16px 8px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .nav-wrap .ctx-tooltip-name{
    font-family: 'Syne', sans-serif;
    font-size: 14px;
    font-weight: 700;
    color: var(--text-primary);
  }

  .nav-wrap .ctx-tooltip-tag{
    font-size: 9px;
    font-weight: 700;
    background: var(--cox-blue-light);
    color: var(--cox-blue);
    padding: 2px 7px;
    border-radius: 4px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-left: auto;
    flex-shrink: 0;
  }

  .nav-wrap .ctx-tooltip-actions{ padding: 6px 8px 8px; }

  .nav-wrap .ctx-tooltip-action{
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 7px 8px;
    border-radius: 8px;
    transition: background 0.1s;
  }

  .nav-wrap .ctx-tooltip-action:hover{ background: var(--light); }

  .nav-wrap .ctx-tooltip-icon{
    width: 26px; height: 26px;
    border-radius: 6px;
    background: var(--cox-blue-light);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    flex-shrink: 0;
  }

  .nav-wrap .ctx-tooltip-action-text{
    font-size: 12px;
    color: var(--text-secondary);
    line-height: 1.35;
    font-weight: 500;
  }



/* ── Resource Launcher Tab Styles ─────────────────── */

  /* ── Reset & tokens ─────────────────────────────────────────────────────── */
  

  .rl-wrap{
    --black:    #06262D;
    --cyan:     #00BCDD;
    --blue:     #1D3E74;
    --orange:   #FF6B35;
    --grey:     #5A6875;
    --grey-lt:  #8fa3ae;
    --off-white:#F4F7F9;
    --white:    #FFFFFF;
    --ink:      #0d2b33;

    --page-max: 1600px;
    --gutter:   clamp(24px, 4vw, 80px);

    --ff-display: 'Playfair Display', Georgia, serif;
    --ff-body:    'DM Sans', system-ui, sans-serif;
    --ff-mono:    'DM Mono', 'Courier New', monospace;

    --ease-out: cubic-bezier(0.22, 1, 0.36, 1);
  }

  

  

  /* ── Utility ─────────────────────────────────────────────────────────────── */
  .rl-wrap .wrap{
    max-width: var(--page-max);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }

  /* ── Hero ─────────────────────────────────────────────────────────────────── */
  .rl-wrap .hero{
    background: var(--black);
    position: relative;
    overflow: hidden;
    padding: 0;
  }

  /* Ray pattern SVG bg */
  .rl-wrap .hero__rays{
    position: absolute;
    inset: 0;
    opacity: .08;
    pointer-events: none;
  }

  /* Cyan / orange accent bar at very top */
  .rl-wrap .hero::before{
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 5px;
    background: linear-gradient(90deg, var(--cyan) 60%, var(--orange) 100%);
    z-index: 2;
  }

  .rl-wrap .hero__inner{
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 48px;
    padding-block: 80px 64px;
  }

  @media (max-width: 900px) {
    .rl-wrap .hero__inner{ grid-template-columns: 1fr; }
    .rl-wrap .hero__visual{ display: none; }
  }

  .rl-wrap .hero__eyebrow{
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--cyan);
    margin-bottom: 20px;
  }

  .rl-wrap .hero__eyebrow span{
    display: inline-block;
    width: 28px; height: 2px;
    background: var(--cyan);
    border-radius: 2px;
  }

  .rl-wrap .hero__title{
    font-family: var(--ff-display);
    font-size: clamp(36px, 4.5vw, 64px);
    font-weight: 900;
    line-height: 1.1;
    color: var(--white);
    margin-bottom: 20px;
  }

  .rl-wrap .hero__title em{
    font-style: normal;
    color: var(--cyan);
  }

  .rl-wrap .hero__desc{
    font-size: 17px;
    font-weight: 300;
    color: #8fb8c6;
    max-width: 520px;
    margin-bottom: 36px;
    line-height: 1.7;
  }

  .rl-wrap .hero__cta{
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--cyan);
    color: var(--black);
    font-weight: 600;
    font-size: 14px;
    padding: 14px 28px;
    border-radius: 8px;
    text-decoration: none;
    letter-spacing: .02em;
    transition: transform .2s var(--ease-out), box-shadow .2s;
    box-shadow: 0 0 0 0 rgba(0,188,221,.4);
  }

  .rl-wrap .hero__cta:hover{
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(0,188,221,.35);
  }

  .rl-wrap .hero__cta svg{ flex-shrink: 0; }

  /* Popup mockup in hero */
  .rl-wrap .hero__visual{
    display: flex;
    justify-content: center;
    align-items: flex-start;
  }

  .rl-wrap .popup-mock{
    width: 296px;
    background: var(--white);
    border-radius: 14px;
    overflow: hidden;
    box-shadow:
      0 2px 4px rgba(0,0,0,.08),
      0 8px 24px rgba(0,0,0,.18),
      0 24px 64px rgba(0,0,0,.28);
    transform: perspective(900px) rotateY(-8deg) rotateX(2deg);
    animation: float 5s ease-in-out infinite;
  }

  @keyframes float {
    0%,100% { transform: perspective(900px) rotateY(-8deg) rotateX(2deg) translateY(0); }
    50%      { transform: perspective(900px) rotateY(-8deg) rotateX(2deg) translateY(-10px); }
  }

  .rl-wrap .popup-mock__header{
    background: linear-gradient(135deg, var(--black) 0%, var(--blue) 100%);
    padding: 16px 16px 14px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .rl-wrap .popup-mock__hamburger{
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .rl-wrap .popup-mock__hamburger span{
    display: block;
    height: 2.5px;
    background: var(--white);
    border-radius: 2px;
  }

  .rl-wrap .popup-mock__hamburger span:nth-child(1){ width: 20px; }
  .rl-wrap .popup-mock__hamburger span:nth-child(2){ width: 16px; }
  .rl-wrap .popup-mock__hamburger span:nth-child(3){ width: 12px; }

  .rl-wrap .popup-mock__titles{ flex: 1; }

  .rl-wrap .popup-mock__name{
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .08em;
    color: var(--white);
    text-transform: uppercase;
    line-height: 1;
    margin-bottom: 4px;
  }

  .rl-wrap .popup-mock__sub{
    font-size: 10px;
    color: rgba(255,255,255,.55);
    font-weight: 300;
  }

  .rl-wrap .popup-mock__bar{
    height: 4px;
    background: linear-gradient(90deg, var(--cyan), var(--orange));
  }

  .rl-wrap .popup-mock__list{ padding: 4px 0 8px; }

  .rl-wrap .popup-mock__item{
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 14px;
    border-bottom: 1px solid #f0f4f6;
    cursor: default;
    transition: background .15s;
  }

  .rl-wrap .popup-mock__item:last-child{ border-bottom: none; }
  .rl-wrap .popup-mock__item:first-child{ background: #e8f7fb; }

  .rl-wrap .popup-mock__icon{
    width: 30px; height: 30px;
    border-radius: 7px;
    background: #e4f3f8;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    flex-shrink: 0;
  }

  .rl-wrap .popup-mock__label{ flex: 1; }

  .rl-wrap .popup-mock__label strong{
    display: block;
    font-size: 11.5px;
    font-weight: 600;
    color: #0d2b33;
    line-height: 1.2;
  }

  .rl-wrap .popup-mock__label small{
    font-size: 9.5px;
    color: var(--grey);
    font-weight: 400;
  }

  .rl-wrap .popup-mock__chevron{
    color: #b0c8d4;
    font-size: 11px;
  }

  .rl-wrap .popup-mock__footer{
    background: #f7fafc;
    padding: 6px 14px;
    font-size: 9px;
    color: var(--grey-lt);
    text-align: center;
    border-top: 1px solid #e8eef2;
  }

  /* ── Section scaffolding ─────────────────────────────────────────────────── */
  .rl-wrap .section{
    padding-block: 72px;
  }

  .rl-wrap .section--alt{ background: var(--white); }
  .rl-wrap .section--dark{ background: var(--black); color: var(--white); }

  .rl-wrap .section__label{
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--cyan);
    margin-bottom: 12px;
  }

  .rl-wrap .section__label::before{
    content: '';
    display: inline-block;
    width: 20px; height: 2px;
    background: currentColor;
    border-radius: 2px;
  }

  .rl-wrap .section__title{
    font-family: var(--ff-display);
    font-size: clamp(28px, 3vw, 44px);
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 16px;
    color: inherit;
  }

  .rl-wrap .section__lead{
    font-size: 17px;
    font-weight: 300;
    color: var(--grey);
    max-width: 640px;
    margin-bottom: 48px;
    line-height: 1.75;
  }

  .rl-wrap .section--dark .section__lead{ color: #7ba8b8; }

  /* ── What is it ──────────────────────────────────────────────────────────── */
  .rl-wrap .what-grid{
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 48px;
  }

  @media (max-width: 900px) {
    .rl-wrap .what-grid{ grid-template-columns: 1fr; }
  }

  .rl-wrap .what-card{
    background: var(--off-white);
    border: 1.5px solid #dde8ed;
    border-radius: 14px;
    padding: 32px 28px;
    position: relative;
    overflow: hidden;
    transition: border-color .2s, transform .2s var(--ease-out);
  }

  .rl-wrap .what-card:hover{
    border-color: var(--cyan);
    transform: translateY(-4px);
  }

  .rl-wrap .what-card::before{
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: var(--cyan);
    opacity: 0;
    transition: opacity .2s;
  }

  .rl-wrap .what-card:hover::before{ opacity: 1; }

  .rl-wrap .what-card__num{
    font-family: var(--ff-display);
    font-size: 48px;
    font-weight: 900;
    color: #d4e8ee;
    line-height: 1;
    margin-bottom: 12px;
  }

  .rl-wrap .what-card__title{
    font-size: 17px;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 8px;
  }

  .rl-wrap .what-card__body{
    font-size: 14.5px;
    color: var(--grey);
    line-height: 1.65;
  }

  /* ── Install steps ───────────────────────────────────────────────────────── */
  .rl-wrap .steps{
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-top: 48px;
    position: relative;
  }

  .rl-wrap .steps::before{
    content: '';
    position: absolute;
    left: 27px;
    top: 52px;
    bottom: 52px;
    width: 2px;
    background: linear-gradient(to bottom, var(--cyan), var(--blue));
    opacity: .3;
  }

  .rl-wrap .step{
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: 28px;
    padding-block: 28px;
    align-items: start;
    opacity: 0;
    transform: translateX(-20px);
    animation: slideIn .5s var(--ease-out) forwards;
  }

  .rl-wrap .step:nth-child(1){ animation-delay: .1s; }
  .rl-wrap .step:nth-child(2){ animation-delay: .2s; }
  .rl-wrap .step:nth-child(3){ animation-delay: .3s; }
  .rl-wrap .step:nth-child(4){ animation-delay: .4s; }
  .rl-wrap .step:nth-child(5){ animation-delay: .5s; }

  @keyframes slideIn {
    to { opacity: 1; transform: none; }
  }

  .rl-wrap .step__num{
    width: 56px; height: 56px;
    border-radius: 50%;
    background: var(--black);
    border: 2.5px solid var(--cyan);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--ff-display);
    font-size: 20px;
    font-weight: 900;
    color: var(--cyan);
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }

  .rl-wrap .step__body{}

  .rl-wrap .step__title{
    font-size: 18px;
    font-weight: 600;
    color: var(--white);
    margin-bottom: 6px;
    margin-top: 14px;
  }

  .rl-wrap .step__desc{
    font-size: 14.5px;
    color: #7ba8b8;
    line-height: 1.7;
    max-width: 640px;
  }

  .rl-wrap .step__desc a{
    color: var(--cyan);
    text-decoration: none;
    border-bottom: 1px dashed rgba(0,188,221,.4);
    transition: border-color .15s;
  }

  .rl-wrap .step__desc a:hover{ border-color: var(--cyan); }

  .rl-wrap .step__pill{
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 12px;
    background: rgba(0,188,221,.12);
    border: 1px solid rgba(0,188,221,.25);
    color: var(--cyan);
    font-size: 12px;
    font-family: var(--ff-mono);
    padding: 5px 12px;
    border-radius: 6px;
  }

  /* ── Reports catalog ─────────────────────────────────────────────────────── */
  .rl-wrap .reports-grid{
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 20px;
    margin-top: 48px;
  }

  .rl-wrap .report-card{
    background: var(--white);
    border: 1.5px solid #dde8ed;
    border-radius: 14px;
    padding: 24px 24px 20px;
    display: flex;
    gap: 16px;
    align-items: flex-start;
    transition: border-color .2s, box-shadow .2s, transform .2s var(--ease-out);
    position: relative;
    overflow: hidden;
  }

  .rl-wrap .report-card::after{
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(0,188,221,.04), transparent 60%);
    opacity: 0;
    transition: opacity .25s;
  }

  .rl-wrap .report-card:hover{
    border-color: var(--cyan);
    box-shadow: 0 4px 20px rgba(0,188,221,.12);
    transform: translateY(-3px);
  }

  .rl-wrap .report-card:hover::after{ opacity: 1; }

  .rl-wrap .report-card__icon{
    width: 46px; height: 46px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    flex-shrink: 0;
    background: var(--off-white);
  }

  .rl-wrap .report-card__body{ flex: 1; }

  .rl-wrap .report-card__name{
    font-size: 15px;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 4px;
  }

  .rl-wrap .report-card__desc{
    font-size: 13.5px;
    color: var(--grey);
    line-height: 1.55;
  }

  .rl-wrap .report-card__tag{
    display: inline-block;
    margin-top: 10px;
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: .06em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 20px;
    background: #e8f7fb;
    color: var(--cyan);
  }

  /* ── Tips ─────────────────────────────────────────────────────────────────── */
  .rl-wrap .tips-grid{
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-top: 48px;
  }

  @media (max-width: 700px) {
    .rl-wrap .tips-grid{ grid-template-columns: 1fr; }
  }

  .rl-wrap .tip-card{
    background: var(--white);
    border: 1.5px solid #dde8ed;
    border-radius: 14px;
    padding: 28px 28px 24px;
  }

  .rl-wrap .tip-card__icon{
    font-size: 28px;
    margin-bottom: 14px;
    display: block;
  }

  .rl-wrap .tip-card__title{
    font-size: 16px;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 8px;
  }

  .rl-wrap .tip-card__body{
    font-size: 14px;
    color: var(--grey);
    line-height: 1.65;
  }

  /* ── FAQ ──────────────────────────────────────────────────────────────────── */
  .rl-wrap .faq{ margin-top: 48px; }

  .rl-wrap .faq-item{
    border-bottom: 1px solid #dde8ed;
  }

  .rl-wrap .faq-item summary{
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 0;
    font-size: 15.5px;
    font-weight: 500;
    color: var(--ink);
    cursor: pointer;
    list-style: none;
    gap: 16px;
  }

  .rl-wrap .faq-item summary::-webkit-details-marker{ display: none; }

  .rl-wrap .faq-item summary::after{
    content: '+';
    font-size: 22px;
    color: var(--cyan);
    font-weight: 300;
    flex-shrink: 0;
    transition: transform .2s;
  }

  .rl-wrap .faq-item[open] summary::after{
    transform: rotate(45deg);
  }

  .rl-wrap .faq-item p{
    font-size: 14.5px;
    color: var(--grey);
    line-height: 1.7;
    padding-bottom: 20px;
    max-width: 720px;
  }

  /* ── Footer ───────────────────────────────────────────────────────────────── */
  .rl-wrap .footer{
    background: var(--black);
    border-top: 1px solid rgba(255,255,255,.06);
    padding-block: 40px;
    text-align: center;
  }

  .rl-wrap .footer__bar{
    height: 3px;
    background: linear-gradient(90deg, var(--cyan), var(--blue), var(--orange));
    margin-bottom: 32px;
    border-radius: 2px;
  }

  .rl-wrap .footer__logo{
    font-family: var(--ff-display);
    font-size: 20px;
